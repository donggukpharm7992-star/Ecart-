{
  "name": "hospital-inventory-check",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:data": "node scripts/run_python.mjs scripts/extract_inventory.py",
    "generate:labels": "node scripts/run_python.mjs \"약제팀 라벨/extract_hospital_labels.py\"",
    "generate:label-matches": "node scripts/run_python.mjs \"약제팀 라벨/extract_pharmacy_label_matches.py\"",
    "generate:narcotic-labels": "node scripts/run_python.mjs scripts/extract_narcotic_labels.py",
    "autosync:hospital-drugs": "node scripts/watch_hospital_drug_list.mjs",
    "autosync:hospital-drugs:install": "node scripts/watch_hospital_drug_list.mjs --install",
    "validate:data": "node scripts/run_python.mjs scripts/validate_inventory.py",
    "test": "vitest run --no-watch --reporter=basic --testTimeout=10000 --config vitest.config.ts",
    "dev": "vite --host 0.0.0.0",
    "dev:public": "node scripts/dev_public.mjs",
    "build": "tsc --noEmit && vite build && node scripts/create_pwa_routes.mjs",
    "publish": "node scripts/publish_gh_pages.mjs",
    "publish:login": "node scripts/publish_gh_pages.mjs --login",
    "release": "node scripts/release_app.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cloudflared": "^0.7.1",
    "vitest": "^4.1.9"
  }
}
